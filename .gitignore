# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Assets は Git LFS で管理する（.gitattributes 参照）。
# 以前は asset/ 全体を除外していたため、クローンしただけではゲームが起動しなかった。
# BGM(mp3)のみ、第三者素材(d-elf.com)で再配布の可否が未確認のため当面は除外する。
asset/*.mp3

# Logs
logs/
*.log
crash_log.txt

# User data
ranking.json
settings.json

# 作業メモ・スクラッチ
__ignore_*
car.txt

# スクリーンショット（ルート直下のみ。asset/ は上で除外済み、docs/ の画像は対象外）
/*.png

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
