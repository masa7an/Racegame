# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Assets (managed outside git)
# 「asset/」ではなく「asset/*」にしてあるのは、ディレクトリ自体を除外すると
# gitがその中のファイルを再包含できず、下の !asset/screenshot.png が効かなくなるため。
asset/*
# READMEが参照するスクリーンショットだけは例外（除外すると公開ページで画像リンクが壊れる）。
!asset/screenshot.png

# Logs
logs/
*.log
crash_log.txt

# User data
ranking.json
settings.json

# 作業メモ・スクラッチ
__ignore_*
car.txt

# スクリーンショット（ルート直下のみ。asset/ は上で除外済み、docs/ の画像は対象外）
/*.png

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
